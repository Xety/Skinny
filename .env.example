# ===========================================
# Skinny Bot - Configuration Environnement
# ===========================================
# Copiez ce fichier en .env et remplissez les valeurs

# Mode de l'application
APP_DEBUG=true
APP_DEV=true

# Configuration du Bot Discord
BOT_TOKEN=your_discord_bot_token_here
BOT_GAME=https://ark-division.fr
BOT_STATUS=online
BOT_USERNAME=Skinny
BOT_AVATAR=https://i.imgur.com/f9L2InC.png

# API ARK Division
API_URL=https://api.ark-division.fr/v1/
API_TOKEN=your_api_token_here

# Discord Guild
DISCORD_GUILD_ID=386615163165605889

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/your_webhook_here

# Préfixe des commandes
COMMAND_PREFIX=!
