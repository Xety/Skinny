{
    "name": "zoro/ark-division",
    "description": "A framework to create discord bot in PHP.",
    "homepage": "https://github.com/SkinnyBot/Skinny-Skeleton",
    "keywords": [
        "discord",
        "bot",
        "php",
        "discordphp",
        "botphp",
        "skinny"
    ],
    "type": "project",
    "license": "MIT",
    "support": {
        "source": "https://github.com/SkinnyBot/Skinny-Skeleton",
        "issues": "https://github.com/SkinnyBot/Skinny-Skeleton/issues"
    },
    "authors": [
        {
            "name": "Xety",
            "email": "zoro.fmt@gmail.com",
            "homepage": "https://github.com/Xety"
        }
    ],
    "require": {
        "php": ">=8.1",
        "skinnybot/plugin-installer": "^2.0",
        "cakephp/chronos": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "team-reflex/discord-php": "^10.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "~3.0"
    },
    "autoload": {
        "psr-4": {
            "Skinny\\": "src"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests"
        }
    },
    "scripts": {
        "post-autoload-dump": "Skinny\\Composer\\Installer\\PluginInstaller::postAutoloadDump"
    },
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "skinnybot/plugin-installer": true
        }
    }
}
